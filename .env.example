# Root env — read by docker-compose. Copy to .env and fill in real values.
# (For local non-Docker dev, backend/.env is used instead — see backend/.env.example)

# OpenRouter API (OpenAI-compatible) — LLM intent parsing.
# Single slug or comma-separated fallback list (max 3).
OPENROUTER_API_KEY="your-openrouter-api-key"
OPENROUTER_MODEL="openai/gpt-oss-120b:free,nvidia/nemotron-3-super-120b-a12b:free,openai/gpt-oss-20b:free"

# Meta WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN="your-whatsapp-access-token"
WHATSAPP_PHONE_NUMBER_ID="your-whatsapp-phone-number-id"
WHATSAPP_VERIFY_TOKEN="bluewings_verify_token_12345"

# Reseed mock flights/bookings when the backend container starts (demo convenience)
SEED_ON_START=true

# Public URL of n8n when exposing the webhook to Meta (e.g. via ngrok)
# N8N_PUBLIC_URL=https://<your-ngrok-id>.ngrok.app
