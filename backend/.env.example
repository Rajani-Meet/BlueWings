DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bluewings?schema=public"
PORT=4000

# OpenRouter API (OpenAI-compatible) — used for LLM intent parsing.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=""
# Single slug, or a comma-separated fallback list (max 3) — useful for :free models
# that rate-limit sporadically; OpenRouter serves from the first available.
OPENROUTER_MODEL="openai/gpt-oss-120b:free,nvidia/nemotron-3-super-120b-a12b:free,openai/gpt-oss-20b:free"
# Optional overrides:
# OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
# OPENROUTER_APP_URL="http://localhost:3000"
# OPENROUTER_APP_TITLE="BlueWings Conversational Booking"
# LLM_TIMEOUT_MS=9000

# WhatsApp Cloud API configuration
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_VERIFY_TOKEN="bluewings_verify_token_12345"
